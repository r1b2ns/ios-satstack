// Debug.xcconfig
// Imports local settings (bundle IDs, team, Mempool Monitor host).
#include "Local.xcconfig"

// ── Bitcoin Network ──────────────────────────────────────────────────────
// Active network: "signet" for testing, "bitcoin" for mainnet.
BDK_NETWORK = signet

// Mempool.space base (no scheme — "://" starts a comment in xcconfig).
// Used to derive Esplora API and block explorer URLs.
BDK_MEMPOOL_BASE = mempool.space/signet

// Electrum server host:port for wallet sync.
BDK_ELECTRUM_HOST = mempool.space:60602
